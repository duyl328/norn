{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Norn",
  "version": "0.2.2",
  "identifier": "com.norn.workbench",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Norn",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "transparent": true,
        "windowEffects": {
          "effects": ["sidebar"],
          "state": "followsWindowActiveState"
        },
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 16,
          "y": 22
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "macOS": {
      "signingIdentity": "-"
    },
    "fileAssociations": [
      {
        "ext": [
          "txt",
          "text",
          "log",
          "md",
          "markdown",
          "mdx",
          "json",
          "jsonc",
          "json5",
          "toml",
          "yaml",
          "yml",
          "xml",
          "svg",
          "csv",
          "tsv",
          "ini",
          "conf",
          "cfg",
          "env",
          "properties",
          "diff",
          "patch",
          "sql",
          "html",
          "htm",
          "css",
          "scss",
          "sass",
          "less",
          "js",
          "mjs",
          "cjs",
          "jsx",
          "ts",
          "mts",
          "cts",
          "tsx",
          "java",
          "py",
          "pyw",
          "pyi",
          "rs",
          "go",
          "rb",
          "php",
          "c",
          "h",
          "cpp",
          "cc",
          "cxx",
          "hpp",
          "cs",
          "swift",
          "kt",
          "kts",
          "scala",
          "dart",
          "lua",
          "pl",
          "pm",
          "r",
          "jl",
          "hs",
          "ex",
          "exs",
          "erl",
          "clj",
          "cljs",
          "fs",
          "fsx",
          "zig",
          "nix",
          "sh",
          "bash",
          "zsh",
          "fish",
          "ps1",
          "psm1",
          "bat",
          "cmd",
          "dockerfile",
          "proto",
          "graphql",
          "gql",
          "vue",
          "svelte",
          "astro"
        ],
        "name": "Norn Text File",
        "description": "Text and source files",
        "mimeType": "text/plain",
        "role": "Editor",
        "rank": "Alternate"
      }
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM3QzM4RUY0M0Q3NzMwQzgKUldUSU1IYzk5STdETnpSalRtQm5uODFvcmlmZVRka0huU3o0TnNOc0R6Z0liaGE2VEZSc3NST3oK",
      "endpoints": ["https://github.com/duyl328/norn/releases/latest/download/latest.json"]
    }
  }
}
